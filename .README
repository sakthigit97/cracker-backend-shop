aws dynamodb create-table `
  --table-name Users-dev `
  --attribute-definitions AttributeName=mobile,AttributeType=S `
  --key-schema AttributeName=mobile,KeyType=HASH `
  --billing-mode PAY_PER_REQUEST `
  --region ap-south-1


aws dynamodb put-item `
  --table-name Users-dev `
  --item file://user.json `
  --region ap-south-1


  aws dynamodb create-table `
  --table-name Categories `
  --attribute-definitions `
    AttributeName=categoryId,AttributeType=S `
  --key-schema `
    AttributeName=categoryId,KeyType=HASH `
  --billing-mode PAY_PER_REQUEST `
  --region ap-south-1

  aws dynamodb create-table `
  --table-name Brands `
  --attribute-definitions `
    AttributeName=brandId,AttributeType=S `
  --key-schema `
    AttributeName=brandId,KeyType=HASH `
  --billing-mode PAY_PER_REQUEST `
  --region ap-south-1

aws dynamodb create-table `
  --table-name Products `
  --attribute-definitions `
    AttributeName=productId,AttributeType=S `
    AttributeName=categoryId,AttributeType=S `
    AttributeName=brandId,AttributeType=S `
    AttributeName=isActive,AttributeType=S `
  --key-schema `
    AttributeName=productId,KeyType=HASH `
  --global-secondary-indexes file://products-gsi.json `
  --billing-mode PAY_PER_REQUEST `
  --region ap-south-1

aws dynamodb create-table `
  --table-name Discounts `
  --attribute-definitions `
    AttributeName=discountId,AttributeType=S `
  --key-schema `
    AttributeName=discountId,KeyType=HASH `
  --billing-mode PAY_PER_REQUEST `
  --region ap-south-1




aws dynamodb put-item --table-name Categories --item file://dbmock/category-lakshmi.json --region ap-south-1
aws dynamodb put-item --table-name Categories --item file://dbmock/category-bomb.json --region ap-south-1

aws dynamodb put-item --table-name Brands --item file://dbmock/brand-standard.json --region ap-south-1

aws dynamodb put-item --table-name Products --item file://dbmock/product-1001.json --region ap-south-1
aws dynamodb put-item --table-name Products --item file://dbmock/product-1002.json --region ap-south-1

aws dynamodb put-item --table-name Discounts --item file://dbmock/discount-cat-lakshmi.json --region ap-south-1


aws dynamodb create-table --table-name Carts --attribute-definitions AttributeName=cartId,AttributeType=S AttributeName=itemId,AttributeType=S --key-schema AttributeName=cartId,KeyType=HASH AttributeName=itemId,KeyType=RANGE --billing-mode PAY_PER_REQUEST --region ap-south-1








service: cracker-backend

provider:
  name: aws
  runtime: nodejs24.x
  region: ap-south-1
  stage: dev

  environment:
    JWT_SECRET: ${env:JWT_SECRET}
    CART_TABLE: Carts
    PRODUCTS_TABLE: Products
    ORDERS_TABLE: Orders

  httpApi:
    payload: "2.0"
    binaryMediaTypes:
      - application/pdf
    cors:
      allowedOrigins:
        - http://localhost:5173
      allowedHeaders:
        - Content-Type
        - Authorization
        - x-guest-id
      allowedMethods:
        - GET
        - POST
        - PUT
        - DELETE
      allowCredentials: false

  iam:
    role:
      statements:
        - Effect: Allow
          Action:
            - dynamodb:GetItem
            - dynamodb:PutItem
            - dynamodb:UpdateItem
            - dynamodb:Query
            - dynamodb:Scan
            - dynamodb:DeleteItem
            - dynamodb:BatchGetItem
          Resource:
            - arn:aws:dynamodb:ap-south-1:*:table/Users-dev
            - arn:aws:dynamodb:ap-south-1:*:table/Products
            - arn:aws:dynamodb:ap-south-1:*:table/Products*
            - arn:aws:dynamodb:ap-south-1:*:table/Products/index/*
            - arn:aws:dynamodb:ap-south-1:*:table/Categories
            - arn:aws:dynamodb:ap-south-1:*:table/Brands
            - arn:aws:dynamodb:ap-south-1:*:table/Discounts
            - arn:aws:dynamodb:ap-south-1:*:table/Carts*
            - arn:aws:dynamodb:ap-south-1:*:table/Orders
            - arn:aws:dynamodb:ap-south-1:*:table/Orders/index/*

functions:
  login:
    handler: src/auth/login.handler
    events:
      - httpApi:
          path: /auth/login
          method: post

  sendOtp:
    handler: src/auth/send-otp.handler
    events:
      - httpApi:
          path: /auth/register/send-otp
          method: post

  register:
    handler: src/auth/register.handler
    events:
      - httpApi:
          path: /auth/register/verify
          method: post

  getProfile:
    handler: src/user/get-profile.main
    events:
      - httpApi:
          path: /user/profile
          method: get

  updateProfile:
    handler: src/user/update-profile.main
    events:
      - httpApi:
          path: /user/profile
          method: put

  getProducts:
    handler: src/handlers/getProducts.handler
    events:
      - httpApi:
          path: /products
          method: get

  getProductDetails:
    handler: src/handlers/getProductDetails.handler
    events:
      - httpApi:
          path: /products/details/{productId}
          method: get

  getProductsByCategory:
    handler: src/handlers/getProductsByCategory.handler
    events:
      - httpApi:
          path: /products/category/{categoryId}
          method: get

  getProductsByBrand:
    handler: src/handlers/getProductsByBrand.handler
    events:
      - httpApi:
          path: /products/brand/{brandId}
          method: get

  getCategories:
    handler: src/handlers/getCategories.handler
    events:
      - httpApi:
          path: /categories
          method: get

  getBrands:
    handler: src/handlers/getBrands.handler
    events:
      - httpApi:
          path: /brands
          method: get

  getCart:
    handler: src/handlers/cart.getCart
    events:
      - httpApi:
          path: /cart
          method: GET

  addCartItem:
    handler: src/handlers/cart.addItem
    events:
      - httpApi:
          path: /cart/add
          method: POST

  removeCartItem:
    handler: src/handlers/cart.removeItem
    events:
      - httpApi:
          path: /cart/remove
          method: POST

  clearCart:
    handler: src/handlers/cart.clearCart
    events:
      - httpApi:
          path: /cart/clear
          method: POST

  productBatch:
    handler: src/handlers/productBatch.handler
    events:
      - httpApi:
          path: /products/batch
          method: POST

  cartMerge:
    handler: src/handlers/cartMerge.handler
    events:
      - httpApi:
          path: /cart/merge
          method: POST

  cartSync:
    handler: src/handlers/cartSync.handler
    events:
      - httpApi:
          path: /cart/sync
          method: POST

  createOrder:
    handler: src/handlers/Orders.handler
    events:
      - httpApi:
          path: /orders
          method: POST

  getOrders:
    handler: src/handlers/getOrders.handler
    events:
      - httpApi:
          path: /orders
          method: GET

  cancelOrder:
    handler: src/handlers/cancelOrder.handler
    events:
      - httpApi:
          path: /orders/{orderId}/cancel
          method: PUT

  adjustOrder:
    handler: src/handlers/adjustOrder.handler
    events:
      - httpApi:
          path: /orders/{orderId}/adjust
          method: put

  adminDashboard:
    handler: src/handlers/adminDashboard.handler
    events:
      - httpApi:
          path: /admin/dashboard
          method: GET

resources:
  Resources:

    UsersTable:
      Type: AWS::DynamoDB::Table
      Properties:
        TableName: Users
        BillingMode: PAY_PER_REQUEST

        AttributeDefinitions:
          - AttributeName: mobile
            AttributeType: S

        KeySchema:
          - AttributeName: mobile
            KeyType: HASH

    BrandsTable:
      Type: AWS::DynamoDB::Table
      Properties:
        TableName: Brands
        BillingMode: PAY_PER_REQUEST

        AttributeDefinitions:
          - AttributeName: brandId
            AttributeType: S

        KeySchema:
          - AttributeName: brandId
            KeyType: HASH

    CategoriesTable:
      Type: AWS::DynamoDB::Table
      Properties:
        TableName: Categories
        BillingMode: PAY_PER_REQUEST

        AttributeDefinitions:
          - AttributeName: categoryId
            AttributeType: S

        KeySchema:
          - AttributeName: categoryId
            KeyType: HASH

    OrdersTable:
      Type: AWS::DynamoDB::Table
      Properties:
        TableName: Orders
        BillingMode: PAY_PER_REQUEST

        AttributeDefinitions:
          - AttributeName: orderId
            AttributeType: S
          - AttributeName: meta
            AttributeType: S
          - AttributeName: userId
            AttributeType: S
          - AttributeName: createdAt
            AttributeType: N

        KeySchema:
          - AttributeName: orderId
            KeyType: HASH
          - AttributeName: meta
            KeyType: RANGE

        GlobalSecondaryIndexes:
          - IndexName: userId-createdAt-index
            KeySchema:
              - AttributeName: userId
                KeyType: HASH
              - AttributeName: createdAt
                KeyType: RANGE
            Projection:
              ProjectionType: ALL

          - IndexName: meta-createdAt-index
            KeySchema:
              - AttributeName: meta
                KeyType: HASH
              - AttributeName: createdAt
                KeyType: RANGE
            Projection:
              ProjectionType: ALL

          - IndexName: status-meta-index
            KeySchema:
              - AttributeName: status
                KeyType: HASH
              - AttributeName: meta
                KeyType: RANGE
            Projection:
              ProjectionType: ALL

    ProductsTable:
      Type: AWS::DynamoDB::Table
      Properties:
        TableName: Products
        BillingMode: PAY_PER_REQUEST

        AttributeDefinitions:
          - AttributeName: productId
            AttributeType: S
          - AttributeName: categoryId
            AttributeType: S
          - AttributeName: brandId
            AttributeType: S
          - AttributeName: isActive
            AttributeType: S

        KeySchema:
          - AttributeName: productId
            KeyType: HASH

        GlobalSecondaryIndexes:
          - IndexName: isActive-index
            KeySchema:
              - AttributeName: isActive
                KeyType: HASH
            Projection:
              ProjectionType: ALL

          - IndexName: categoryId-index
            KeySchema:
              - AttributeName: categoryId
                KeyType: HASH
            Projection:
              ProjectionType: ALL

          - IndexName: brandId-index
            KeySchema:
              - AttributeName: brandId
                KeyType: HASH
            Projection:
              ProjectionType: ALL

    DiscountsTable:
      Type: AWS::DynamoDB::Table
      Properties:
        TableName: Discounts
        BillingMode: PAY_PER_REQUEST

        AttributeDefinitions:
          - AttributeName: discountId
            AttributeType: S

        KeySchema:
          - AttributeName: discountId
            KeyType: HASH

    CartsTable:
      Type: AWS::DynamoDB::Table
      Properties:
        TableName: Carts
        BillingMode: PAY_PER_REQUEST

        AttributeDefinitions:
          - AttributeName: cartId
            AttributeType: S
          - AttributeName: itemId
            AttributeType: S

        KeySchema:
          - AttributeName: cartId
            KeyType: HASH
          - AttributeName: itemId
            KeyType: RANGE
